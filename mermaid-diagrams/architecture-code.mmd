flowchart TD
    subgraph Internet [🌐 Internet]
        direction TB
        API1[Public APIs]
    end

    subgraph RaspberryPi [🖥️ Raspberry Pi]
        direction TB
        subgraph PiHole [Pi-hole Server]
            P1[Local File /var/log/pihole.log]
            P2[API Endpoints /api/logs/dnsmasq /api/stats/summary /api/stats/top_domains /api/dns/blocking /api/info/ftl /api/info/system /api/network/gateway]
        end

        subgraph ProducerService [Producer (Systemd Service)]
            PF1[Pi-hole File Monitor]
        end
    end

    subgraph WindowsPC [🖥️ Your Windows PC]
        direction TB
        subgraph Docker [🐳 Docker Services]
            direction TB
            subgraph KafkaCluster [📦 Kafka & Zookeeper]
                K1[Kafka Broker <br/>localhost:9092]
            end
            subgraph KafkaUI [🖥️ Kafka UI]
                UI1[Kafka UI <br/>localhost:8080]
            end
            subgraph PostgreSQL [🗄️ PostgreSQL]
                DB1[PostgreSQL <br/>localhost:5432]
            end
        end

        subgraph PythonApp [🐍 Python Application]
            direction TB
            subgraph Consumers [Consumers]
                C1[Consumer 1 - Logs]
                C2[Consumer 2 - Metrics]
                C3[Consumer 3 - External]
            end
            subgraph Services [Internal Services]
                S1[Random API Server Flask + Faker]
                S2[Kafka Client]
            end
            subgraph Producers [Other Producers]
                PF2[Public API Fetcher]
                PF3[Random API Fetcher]
                PP1[Pi-hole API Logs Poller]
                PP2[Pi-hole Data Poller]
            end
        end
    end

    %% Connections
    API1 --> PF2
    PF2 --> K1
    PF3 --> K1
    PP1 -->|HTTP| P2
    PP2 -->|HTTP| P2
    PP1 --> K1
    PP2 --> K1
    
    P1 --> PF1
    PF1 -->|Local Network| K1
    
    S1 --> PF3

    K1 --> C1
    K1 --> C2
    K1 --> C3

    C1 --> DB1
    C2 --> DB1
    C3 --> DB1

